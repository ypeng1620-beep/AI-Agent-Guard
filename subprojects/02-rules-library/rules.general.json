    "constraint": {
      "name": "约束符合",
      "description": "评估是否满足用户设定的约束条件（格式、风格、长度等）",
      "weight": 0.2,
      "criteria": [
        {
          "score": 100,
          "description": "完全满足所有约束条件"
        },
        {
          "score": 80,
          "description": "满足主要约束，仅有微小偏差"
        },
        {
          "score": 60,
          "description": "基本满足约束，有1-2处轻微偏差"
        },
        {
          "score": 40,
          "description": "部分约束未满足，需要修改"
        },
        {
          "score": 20,
          "description": "多个主要约束未满足"
        },
        {
          "score": 0,
          "description": "完全不符合约束要求"
        }
      ],
      "threshold": 60
    }
