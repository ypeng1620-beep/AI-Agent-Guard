{
  "scenario": "general",
  "version": "2.0.0",
  "description": "通用场景规则库",
  "rules": {
    "forbiddenWords": {
      "core": [
        "毒品", "赌博", "走私", "伪造", "恐怖", "爆炸", "武器", "核弹",
        "自杀", "自残", "谋杀", "投毒", "绑架", "拐卖", "诈骗", "传销",
        "色情", "淫秽", "赌博", "博彩", "外挂", "作弊", "黑产", "洗钱"
      ],
      "extended": [
        "暴力", "血腥", "残忍", "虐待", "性骚扰", "未成年人", "儿童色情",
        "网络攻击", "黑客", "入侵", "破解", "盗号", "窃取", "钓鱼",
        "虚假信息", "谣言", "诽谤", "侮辱", "诬告", "陷害"
      ],
      "contextual": [
        "敏感政治", "分裂国家", "颠覆政权", "非法集会", "抗议活动"
      ]
    },
    "length": {
      "min": 10,
      "max": 10000,
      "recommended": 2000
    },
    "turns": {
      "max": 50,
      "warning": 30
    },
    "quality": {
      "minScore": 60,
      "goodScore": 80
    },
    "safety": {
      "profanity": {
        "action": "block",
        "severity": "high"
      },
      "hateSpeech": {
        "action": "block", 
        "severity": "critical"
      },
      "dangerousContent": {
        "action": "block",
        "severity": "critical"
      }
    },
    "format": {
      "allowHTML": false,
      "allowScript": false,
      "allowIframe": false,
      "allowExternalResource": false
    }
  },
  "presets": {
    "strict": {
      "scoreThreshold": 80,
      "similarityThreshold": 90,
      "consecutiveRounds": 2
    },
    "balanced": {
      "scoreThreshold": 70,
      "similarityThreshold": 80,
      "consecutiveRounds": 3
    },
    "relaxed": {
      "scoreThreshold": 60,
      "similarityThreshold": 70,
      "consecutiveRounds": 5
    }
  }
}
