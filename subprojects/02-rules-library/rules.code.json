{
  "scenario": "code",
  "version": "2.0.0",
  "description": "代码助手场景规则库",
  "rules": {
    "forbiddenWords": {
      "core": [
        "eval", "exec", "system", "popen", "subprocess",
        "__import__", "open(", "file", "os.", "sys.",
        "spawn", "fork", "ctypes", "socket"
      ],
      "extended": [
        "shell", "bash", "sh", "cmd", "powershell",
        "rm -rf", "del /", "format", "wipe",
        "drop table", "delete from", "truncate",
        "inject", "bypass", "rootkit"
      ],
      "contextual": [
        "password", "secret", "token", "api_key", "credential",
        "decrypt", "crack", "hack", "exploit"
      ]
    },
    "length": {
      "min": 5,
      "max": 50000,
      "recommended": 5000
    },
    "turns": {
      "max": 100,
      "warning": 50
    },
    "quality": {
      "minScore": 70,
      "goodScore": 90
    },
    "security": {
      "sqlInjection": {
        "action": "block",
        "severity": "critical"
      },
      "xss": {
        "action": "block",
        "severity": "critical"
      },
      "rce": {
        "action": "block",
        "severity": "critical"
      },
      "pathTraversal": {
        "action": "block",
        "severity": "high"
      },
      "ssrf": {
        "action": "block",
        "severity": "high"
      }
    },
    "codeQuality": {
      "syntaxCheck": true,
      "styleGuide": "standard",
      "complexityLimit": 20,
      "functionLengthLimit": 50
    }
  },
  "languages": {
    "javascript": {
      "maxFileSize": 10000,
      "allowRequire": true,
      "allowNodeAPIs": ["fs.readFile", "path.join"]
    },
    "python": {
      "maxFileSize": 15000,
      "allowImport": ["os", "sys", "json", "re"],
      "banImport": ["ctypes", "subprocess", "socket"]
    },
    "java": {
      "maxFileSize": 20000,
      "allowSystem": false
    }
  },
  "presets": {
    "secure": {
      "securityLevel": "strict",
      "maxFileSize": 5000,
      "allowExternal": false
    },
    "balanced": {
      "securityLevel": "moderate",
      "maxFileSize": 15000,
      "allowExternal": true
    },
    "permissive": {
      "securityLevel": "basic",
      "maxFileSize": 50000,
      "allowExternal": true
    }
  }
}
