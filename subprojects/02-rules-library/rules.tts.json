{
  "scenario": "tts",
  "version": "2.0.0",
  "description": "TTS语音合成场景规则库",
  "rules": {
    "forbiddenWords": {
      "core": [
        "噪音", "刺耳", "过载", "失真", "爆音"
      ],
      "extended": [],
      "contextual": []
    },
    "length": {
      "min": 5,
      "max": 5000,
      "recommended": 1000,
      "perMinute": 150
    },
    "turns": {
      "max": 10,
      "warning": 7
    },
    "quality": {
      "minScore": 70,
      "goodScore": 85
    },
    "tts": {
      "maxDuration": 300,
      "maxSilence": 3,
      "allowSSML": false,
      "allowAudio": false,
      "pitchRange": {
        "min": 0.5,
        "max": 2.0
      },
      "speedRange": {
        "min": 0.5,
        "max": 2.0
      },
      "volumeRange": {
        "min": 0.1,
        "max": 1.0
      }
    },
    "safety": {
      "earDamage": {
        "action": "block",
        "severity": "critical"
      },
      "seizure": {
        "action": "block",
        "severity": "high"
      }
    },
    "pronunciation": {
      "correctness": 0.95,
      "nativeCheck": true,
      "phoneticAmbiguity": false
    }
  },
  "presets": {
    "news": {
      "maxDuration": 180,
      "speed": 1.0,
      "pitch": 1.0
    },
    "story": {
      "maxDuration": 600,
      "speed": 0.9,
      "pitch": 1.1
    },
    "kids": {
      "maxDuration": 300,
      "speed": 0.85,
      "pitch": 1.2,
      "safetyLevel": "strict"
    }
  }
}
