# AI Agent Guard 环境配置示例
# 复制此文件为 .env 并填入实际值

# ========== 服务器配置 ==========
PORT=18791
HOST=0.0.0.0

# ========== 评估引擎配置 ==========
# 可选值: local, doubao, zhipu, kimi
EVAL_MODEL=local

# 默认场景: general, tts, code
DEFAULT_SCENARIO=general

# ========== 浏览器配置 ==========
# Playwright 浏览器端口
BROWSER_PORT=18790

# 浏览器模式: chromium, firefox, webkit
BROWSER_TYPE=chromium

# ========== 路径配置 ==========
# 规则库路径（默认：./subprojects/02-rules-library）
# RULES_PATH=./subprojects/02-rules-library

# 记忆存储路径（默认：./subprojects/07-memory-module）
# MEMORY_PATH=./subprojects/07-memory-module

# ========== 阈值配置 ==========
# 相似度阈值 (0-1)
SIMILARITY_THRESHOLD=0.85

# 分数阈值 (%)
SCORE_THRESHOLD=70

# 连续收敛轮次
CONSECUTIVE_ROUNDS=3

# ========== 日志配置 ==========
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志文件路径
# LOG_PATH=./logs

# 日志文件最大大小 (bytes)
LOG_MAX_SIZE=10485760

# 保留日志文件数量
LOG_MAX_FILES=7

# ========== OpenClaw 配置 ==========
# OpenClaw Gateway 地址
OPENCLAW_URL=http://127.0.0.1:18789

# ========== CORS 配置 ==========
# 允许的来源（生产环境建议设置具体域名）
CORS_ORIGIN=*

# ========== 安全配置 ==========
# 请求体最大大小 (bytes)
MAX_BODY_SIZE=1048576

# 是否启用输入消毒
SANITIZE_INPUT=true
